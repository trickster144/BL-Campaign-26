# Black Legion Cold War Campaign - Backend Environment Configuration
# Copy this to .env and configure with real values

# ============================================================================= 
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=10.0.0.28
DB_PORT=3306
DB_NAME=campaign_data
DB_USER=ash_user_copilot
DB_PASSWORD=Ashleycampaignsql123

# ============================================================================= 
# SERVER CONFIGURATION
# =============================================================================
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:8081

# ============================================================================= 
# STEAM AUTHENTICATION
# =============================================================================
# Get your Steam API key from: https://steamcommunity.com/dev/apikey
# Required for Steam login to work
STEAM_API_KEY=YOUR_STEAM_API_KEY_HERE

# These URLs should match your deployment
STEAM_RETURN_URL=http://localhost:5001/api/auth/steam/callback
STEAM_REALM=http://localhost:5001/

# ============================================================================= 
# SECURITY
# =============================================================================
# JWT Secret for session tokens (CHANGE THIS IN PRODUCTION!)
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_RANDOM_KEY

# ============================================================================= 
# GAME CONFIGURATION
# =============================================================================
TICK_INTERVAL_MS=60000
GAME_START_DATE=2026-04-11T00:00:00Z

# ============================================================================= 
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Visit https://steamcommunity.com/dev/apikey to get your Steam API key
# 2. Replace YOUR_STEAM_API_KEY_HERE with your actual key
# 3. Update FRONTEND_URL to match your frontend deployment URL
# 4. Generate a secure JWT_SECRET for production use
# 5. Update STEAM_RETURN_URL and STEAM_REALM to match your domain
